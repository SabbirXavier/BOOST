rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // 0. Global Safety Net
    match /{document=**} {
      allow read, write: if false;
    }

    // 3. Primitive Definitions
    function isSignedIn() { return request.auth != null; }
    function isEmail(email) { return isSignedIn() && request.auth.token.email.lower() == email.lower(); }
    function isVerified() { return isSignedIn() && (request.auth.token.email_verified == true || isEmail('dcpromoidse@gmail.com')); }
    function isAdmin() { 
      return isSignedIn() && (
        isEmail('dcpromoidse@gmail.com') ||
        (exists(/databases/$(database)/documents/settings/platform) && 
         request.auth.token.email in get(/databases/$(database)/documents/settings/platform).data.allowedAdmins)
      );
    }
    function isValidId(id) { return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$'); }
    function incoming() { return request.resource.data; }
    function existing() { return resource.data; }
    
    // Validation Blueprints
    function isValidStreamer(data) {
      return data.displayName is string && 
             data.username is string && 
             data.role in ['streamer', 'admin'];
    }

    function isValidDonation(data) {
      return data.streamerId is string &&
             data.amount is number &&
             data.donorName is string;
    }

    function isValidWidget(data) {
      return data.streamerId is string &&
             data.type in ['alert', 'goal', 'ticker'] &&
             data.config is map;
    }

    // 0.1 Settings Collection
    match /settings/platform {
      allow read: if true; 
      allow write: if isAdmin();
    }

    // 0.2 Subscription Plans Collection
    match /plans/{planId} {
      allow read: if true; 
      allow write: if isAdmin();
    }

    // 1. Streamers Collection
    match /streamers/{streamerId} {
      allow read: if true;
      allow create: if isVerified() && request.auth.uid == streamerId && isValidStreamer(incoming());
      allow update: if isAdmin() || (isVerified() && request.auth.uid == streamerId);
      allow delete: if isAdmin();
    }

    // 2. Donations Collection
    match /donations/{donationId} {
      allow read: if true;
      allow create: if isValidDonation(incoming());
      allow update: if isAdmin() || (isSignedIn() && (resource.data.streamerId == request.auth.uid || incoming().streamerId == request.auth.uid));
      allow delete: if isAdmin();
    }

    // 3. Widgets Collection
    match /widgets/{widgetId} {
      allow read: if true;
      allow create: if isVerified() && incoming().streamerId == request.auth.uid && isValidWidget(incoming());
      allow update: if isAdmin() || (isVerified() && existing().streamerId == request.auth.uid);
      allow delete: if isAdmin();
    }
  }
}
